<%= content_for :page_title, "Đơn hàng" %>

<%# ── Stats summary ───────────────────────────────────────────────────────── %>
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="admin-card text-center" style="padding:18px 12px;">
      <div style="font-size:28px;font-weight:700;color:#1e293b;"><%= @stats[:total] %></div>
      <div style="font-size:12px;color:#64748b;margin-top:2px;">Tổng đơn hàng</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="admin-card text-center" style="padding:18px 12px;">
      <div style="font-size:28px;font-weight:700;color:#f59e0b;"><%= @stats[:pending] %></div>
      <div style="font-size:12px;color:#64748b;margin-top:2px;">Chờ xử lý</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="admin-card text-center" style="padding:18px 12px;">
      <div style="font-size:28px;font-weight:700;color:#22c55e;"><%= @stats[:paid] %></div>
      <div style="font-size:12px;color:#64748b;margin-top:2px;">Đã thanh toán</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="admin-card text-center" style="padding:18px 12px;">
      <div style="font-size:22px;font-weight:700;color:#6366f1;"><%= number_to_currency(@stats[:revenue], unit: "₫", precision: 0) %></div>
      <div style="font-size:12px;color:#64748b;margin-top:2px;">Tổng giá trị </div>
    </div>
  </div>
</div>

<div class="admin-page-header d-flex flex-wrap justify-content-between align-items-end gap-3">
  <div>
    <h1>Đơn hàng</h1>
    <p class="subtitle">Danh sách tất cả đơn hàng</p>
  </div>

  <%= form_with url: admin_orders_path, method: :get, local: true, class: "admin-search" do %>
    <%= select_tag :kind,
          options_for_select([["Tất cả loại", ""], ["Đấu giá", "auction_win"], ["Mua ngay", "buy_now"]], params[:kind]),
          class: "admin-input", onchange: "this.form.requestSubmit()" %>

    <%= select_tag :status,
          options_for_select([["Tất cả trạng thái", ""], ["Chờ xử lý", "pending"], ["Đã thanh toán", "paid"], ["Đã huỷ", "cancelled"]], params[:status]),
          class: "admin-input", onchange: "this.form.requestSubmit()" %>

    <%= link_to admin_orders_path, class: "admin-btn admin-btn-outline" do %>
      <i class="bi bi-arrow-counterclockwise"></i> Đặt lại
    <% end %>
  <% end %>
</div>

<div class="admin-card">
  <div class="admin-card-header">
    <span class="admin-card-title"><i class="bi bi-bag-check me-1"></i> Đơn hàng</span>
  </div>

  <div class="table-responsive">
    <table class="admin-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Sản phẩm / Người mua</th>
          <th>Loại</th>
          <th>Trạng thái</th>
          <th>Thời gian thanh toán</th>
          <th class="text-center">Người tham gia</th>
          <th class="text-end">Giá</th>
          <th class="text-end">Hành động</th>
        </tr>
      </thead>
      <tbody>
        <% @orders.each do |o| %>
          <tr>
            <td style="color:#94a3b8;font-weight:600;">#<%= o.id %></td>

            <td>
              <div class="fw-semibold" style="color:#1e293b;"><%= o.listing&.title %></div>
              <div style="font-size:12px;color:#94a3b8;">Người mua: <%= o.buyer&.name %></div>
            </td>

            <td>
              <% kind_label = o.kind == "auction_win" ? "Đấu giá" : "Mua ngay" %>
              <span class="admin-badge na"><%= kind_label %></span>
            </td>

            <td>
              <% badge_class = case o.status
                when "paid"      then "paid"
                when "cancelled" then "na"
                else "pending"
                end
                 status_label = case o.status
                when "paid"      then "Đã thanh toán"
                when "cancelled" then "Đã huỷ"
                else "Chờ xử lý"
                end %>
              <span class="admin-badge <%= badge_class %>"><%= status_label %></span>
            </td>

            <td>
              <% paid_at = o.admin_confirmed_paid_at || o.buyer_marked_paid_at %>
              <% if paid_at %>
                <span class="admin-badge published"><i class="bi bi-check2 me-1"></i>Đã TT</span>
                <div style="font-size:11px;color:#94a3b8;margin-top:2px;"><%= l(paid_at, format: :short) rescue paid_at.strftime("%d/%m %H:%M") %></div>
              <% else %>
                <span class="admin-badge na">Chưa</span>
              <% end %>
            </td>

            <td class="text-center">
              <% bid_participants = o.listing&.bids&.select(:user_id)&.distinct&.count || 0 %>
              <span style="font-weight:600;color:#1e293b;"><%= bid_participants %></span>
              <div style="font-size:11px;color:#94a3b8;"><%= o.listing&.bids&.count || 0 %> lượt</div>
            </td>

            <td class="text-end fw-semibold" style="color:#1e293b;">
              <%= number_to_currency(o.price, unit: "₫", precision: 0) rescue o.price %>
            </td>

            <td class="text-end">
              <%= link_to admin_order_path(o), class: "admin-btn admin-btn-primary admin-btn-sm" do %>
                <i class="bi bi-eye"></i> Xem
              <% end %>
            </td>
          </tr>
        <% end %>

        <% if @orders.blank? %>
          <tr>
            <td colspan="8" style="text-align:center;color:#94a3b8;padding:40px 0;">
              <i class="bi bi-bag" style="font-size:28px;display:block;margin-bottom:8px;"></i>
              Không có đơn hàng nào.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div style="padding:16px 20px;display:flex;justify-content:center;">
    <%= paginate @orders %>
  </div>
</div>
