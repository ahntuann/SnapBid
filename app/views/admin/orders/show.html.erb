<%# ── Header ──────────────────────────────────────── %>
<div class="d-flex align-items-center justify-content-between mt-3 mb-3">
  <div>
    <div class="text-muted small">Đơn hàng #<%= @order.id %></div>
    <h1 class="h3 mb-1"><%= @order.listing&.title %></h1>
    <div class="d-flex flex-wrap gap-2">
      <% kind_label = @order.kind == "auction_win" ? "Đấu giá" : "Mua ngay" %>
      <span class="badge text-bg-light border"><i class="bi bi-tag me-1"></i><%= kind_label %></span>

      <% status_badge, status_label =
           if @order.paid?
             ["bg-success", "Đã thanh toán"]
           elsif @order.cancelled?
             ["bg-danger", "Đã huỷ"]
           else
             ["bg-warning text-dark", "Chờ xử lý"]
           end %>
      <span class="badge <%= status_badge %>"><%= status_label %></span>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= link_to "Quay lại", admin_orders_path, class: "btn btn-outline-secondary rounded-pill" %>
    <%= link_to "Xem sản phẩm", listing_path(@order.listing), class: "btn btn-outline-primary rounded-pill", target: "_blank" %>
  </div>
</div>

<div class="row g-3">

  <%# ── Cột trái ──────────────────────────────────── %>
  <div class="col-12 col-lg-8">

    <%# Card: Thông tin đơn hàng %>
    <div class="card border-0 shadow-sm mb-3" style="border-radius:16px;">
      <div class="card-body">
        <div class="fw-semibold mb-3" style="font-size:15px;"><i class="bi bi-receipt me-2 text-primary"></i>Thông tin đơn hàng</div>

        <div class="row g-3">
          <div class="col-6 col-md-4">
            <div class="text-muted small">Người mua</div>
            <div class="fw-semibold"><%= @order.buyer&.name || "—" %></div>
            <div class="text-muted small"><%= @order.buyer&.email %></div>
          </div>

          <div class="col-6 col-md-4">
            <div class="text-muted small">Giá thanh toán</div>
            <div class="fw-bold fs-5" style="color:#1e293b;">
              <%= number_to_currency(@order.price, unit: "₫", precision: 0) rescue @order.price %>
            </div>
          </div>

          <div class="col-6 col-md-4">
            <div class="text-muted small">Thời gian thanh toán</div>
            <div class="fw-semibold">
              <% paid_at = @order.admin_confirmed_paid_at || @order.buyer_marked_paid_at %>
              <% if paid_at %>
                <%= l(paid_at, format: :short) rescue paid_at.strftime("%d/%m/%Y %H:%M") %>
              <% else %>
                <span class="text-muted">Chưa</span>
              <% end %>
            </div>
          </div>
        </div>

        <% if @order.cancelled? %>
          <div class="alert alert-secondary mt-3 mb-0" style="border-radius:12px;">
            <i class="bi bi-x-circle me-1"></i> Đơn hàng đã bị huỷ.
          </div>
        <% end %>
      </div>
    </div>

    <%# Card: Thông tin sản phẩm %>
    <div class="card border-0 shadow-sm mb-3" style="border-radius:16px;">
      <div class="card-body">
        <div class="fw-semibold mb-3" style="font-size:15px;"><i class="bi bi-box me-2 text-warning"></i>Thông tin sản phẩm</div>

        <div class="d-flex gap-3 mb-3">
          <% if @order.listing&.images&.attached? %>
            <div style="width:80px;height:80px;border-radius:12px;overflow:hidden;flex:0 0 auto;">
              <%= image_tag @order.listing.images.first, style: "width:100%;height:100%;object-fit:cover;" %>
            </div>
          <% end %>
          <div>
            <div class="fw-semibold" style="font-size:15px;"><%= @order.listing&.title %></div>
            <div class="text-muted small mt-1">
              <%= @order.listing&.category&.name %> &bull; <%= @order.listing&.condition %>
            </div>
          </div>
        </div>

        <div class="row g-2">
          <div class="col-6 col-md-3">
            <div class="text-muted small">Giá khởi điểm</div>
            <div class="fw-semibold">
              <%= number_to_currency(@order.listing&.start_price, unit: "₫", precision: 0) rescue "—" %>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="text-muted small">Giá mua ngay</div>
            <div class="fw-semibold">
              <% if @order.listing&.buy_now_enabled? %>
                <%= number_to_currency(@order.listing&.buy_now_price, unit: "₫", precision: 0) rescue "—" %>
              <% else %>
                <span class="text-muted">Tắt</span>
              <% end %>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="text-muted small">Số người tham gia</div>
            <div class="fw-semibold">
              <%= @order.listing&.bids&.select(:user_id)&.distinct&.count || 0 %> người
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="text-muted small">Tổng lượt đặt giá</div>
            <div class="fw-semibold"><%= @order.listing&.bids&.count || 0 %> lượt</div>
          </div>
        </div>
      </div>
    </div>

    <%# Card: Lịch sử đấu giá %>
    <div class="card border-0 shadow-sm mb-3" style="border-radius:16px;">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div class="fw-semibold" style="font-size:15px;"><i class="bi bi-clock-history me-2 text-info"></i>Lịch sử đấu giá</div>
          <span class="badge bg-light text-dark border"><%= @order.listing&.bids&.count || 0 %> lượt</span>
        </div>

        <% bids = @order.listing&.bids&.order(created_at: :desc)&.limit(30) %>
        <% if bids.present? %>
          <div class="table-responsive">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Người đặt giá</th>
                  <th class="text-end">Số tiền</th>
                  <th class="text-end">Thời gian</th>
                </tr>
              </thead>
              <tbody>
                <% bids.each_with_index do |b, i| %>
                  <tr>
                    <td style="color:#94a3b8;font-size:12px;"><%= i + 1 %></td>
                    <td>
                      <div class="fw-semibold" style="font-size:13px;"><%= b.user&.name || "—" %></div>
                      <div style="font-size:11.5px;color:#94a3b8;"><%= b.user&.email %></div>
                    </td>
                    <td class="text-end fw-semibold" style="color:#1e293b;">
                      <%= number_to_currency(b.amount, unit: "₫", precision: 0) rescue b.amount %>
                    </td>
                    <td class="text-end" style="font-size:12px;color:#64748b;white-space:nowrap;">
                      <%= b.created_at.strftime("%d/%m/%Y %H:%M") %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-center text-muted py-3">
            <i class="bi bi-inbox" style="font-size:24px;display:block;margin-bottom:6px;"></i>
            Chưa có lượt đặt giá nào.
          </div>
        <% end %>
      </div>
    </div>

  </div>

  <%# ── Cột phải ─────────────────────────────────── %>
  <div class="col-12 col-lg-4">

    <%# Card: Thông tin giao hàng %>
    <div class="card border-0 shadow-sm" style="border-radius:16px;">
      <div class="card-body">
        <div class="fw-semibold mb-3" style="font-size:15px;"><i class="bi bi-truck me-2 text-success"></i>Thông tin giao hàng</div>

        <div class="mb-2">
          <div class="text-muted small">Người nhận</div>
          <div class="fw-semibold"><%= @order.recipient_name.presence || "—" %></div>
        </div>
        <div class="mb-2">
          <div class="text-muted small">Số điện thoại</div>
          <div class="fw-semibold"><%= @order.recipient_phone.presence || "—" %></div>
        </div>
        <div>
          <div class="text-muted small">Địa chỉ</div>
          <div class="fw-semibold"><%= @order.shipping_address.presence || "—" %></div>
        </div>
      </div>
    </div>

  </div>

</div>

