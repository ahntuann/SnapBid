<h1>Chỉnh sửa cài đặt</h1>

<%= form_with model: @settings, url: admin_settings_path do |f| %>
  <div>
    <%= f.label :ai_threshold, "Ngưỡng AI" %><br>
    <%= f.number_field :ai_threshold, step: 0.01 %>
  </div>

  <div>
    <%= f.label :commission_percent, "Hoa hồng %" %><br>
    <%= f.number_field :commission_percent, step: 0.01 %>
  </div>

  <div>
    <%= f.label :min_bid_step, "Bước giá tối thiểu" %><br>
    <%= f.number_field :min_bid_step, step: 1 %>
  </div>

  <%= f.submit "Lưu" %>
<% end %>
