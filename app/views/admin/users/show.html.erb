<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
      <div class="text-muted small">Người dùng #<%= @user.id %></div>
      <h1 class="h3 mb-0"><%= @user.name.presence || "(no name)" %></h1>
      <div class="text-muted"><%= @user.email %></div>
    </div>
    <div class="d-flex gap-2">
      <%= link_to "Quay lại", admin_users_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-12 col-lg-5">
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div class="fw-semibold">Thông tin</div>
            <% if @user.admin? %>
              <span class="badge bg-danger">admin</span>
            <% else %>
              <span class="badge bg-secondary">user</span>
            <% end %>
          </div>
          <hr>
          <div class="text-muted small">ID user</div>
          <div class="fw-semibold mb-2">#<%= @user.id %></div>

          <div class="text-muted small">Số coin hiện tại</div>
          <div class="fw-semibold mb-2" style="color:#0f766e;"><%= number_with_delimiter(@user.snapbid_coins) %> coin</div>

          <div class="text-muted small">Deposit ref</div>
          <div class="fw-semibold mb-2"><%= @user.deposit_ref %></div>

          <div class="text-muted small">Email xác minh</div>
          <div class="fw-semibold mb-2"><%= @user.email_verified? ? "Đã xác minh" : "Chưa xác minh" %></div>

          <div class="text-muted small">Trạng thái seller</div>
          <div class="fw-semibold mb-2"><%= @user.is_seller? ? "Đã bật" : "Chưa bật" %></div>

          <div class="text-muted small">Đăng nhập</div>
          <div class="fw-semibold mb-2"><%= @user.provider.present? ? "#{@user.provider} (OAuth)" : "Email/Password" %></div>

          <div class="text-muted small">Trạng thái tài khoản</div>
          <div class="fw-semibold mb-2">
            <% if @user.locked? %>
              <span class="badge bg-danger"><i class="bi bi-lock"></i> Đã khóa (từ <%= @user.locked_at.strftime("%d/%m/%Y %H:%M") %>)</span>
            <% else %>
              <span class="badge bg-success"><i class="bi bi-unlock"></i> Hoạt động</span>
            <% end %>
          </div>

          <div class="text-muted small">Ngày tạo</div>
          <div class="fw-semibold"><%= @user.created_at.strftime("%d/%m/%Y %H:%M") %></div>
        </div>
      </div>

      <div class="card shadow-sm mt-3">
        <div class="card-body">
          <div class="fw-semibold">Điều chỉnh coin</div>
          <p class="text-muted small mb-3">Nhập số dương để cộng coin, số âm để trừ coin. Bắt buộc có lý do.</p>

          <%= form_with url: adjust_coins_admin_user_path(@user), method: :post, local: true do %>
            <div class="mb-2">
              <label class="form-label">Số coin điều chỉnh</label>
              <input type="number" name="coin_adjustment_amount" class="form-control" placeholder="Ví dụ: 100 hoặc -50" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Lý do</label>
              <textarea name="coin_adjustment_reason" class="form-control" rows="3" placeholder="Ví dụ: Hoàn coin do lỗi đơn hàng" required></textarea>
            </div>

            <button type="submit" class="btn btn-primary w-100">
              <i class="bi bi-wallet2 me-1"></i> Cập nhật coin
            </button>
          <% end %>
        </div>
      </div>

      <div class="card shadow-sm mt-3">
        <div class="card-body">
          <% if @user.locked? %>
            <div class="fw-semibold text-danger mb-2">
              <i class="bi bi-lock-fill"></i> Tài khoản đã khóa
            </div>
            <p class="text-muted small mb-3">Nhấn nút bên dưới để mở khóa và cho phép user sử dụng lại tài khoản.</p>

            <%= form_with url: unlock_account_admin_user_path(@user), method: :post, local: true do %>
              <button type="submit" class="btn btn-success w-100">
                <i class="bi bi-unlock"></i> Mở khóa tài khoản
              </button>
            <% end %>
          <% else %>
            <div class="fw-semibold text-success mb-2">
              <i class="bi bi-unlock-fill"></i> Tài khoản hoạt động
            </div>
            <p class="text-muted small mb-3">Nhập lý do khóa và nhấn nút bên dưới để khóa tài khoản.</p>

            <%= form_with url: lock_account_admin_user_path(@user), method: :post, local: true do %>
              <div class="mb-3">
                <label class="form-label">Lý do khóa</label>
                <textarea name="lock_reason" class="form-control" rows="3" placeholder="Ví dụ: Vi phạm điều khoản dịch vụ" required></textarea>
              </div>

              <button type="submit" class="btn btn-danger w-100">
                <i class="bi bi-lock"></i> Khóa tài khoản
              </button>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-7">
      <div class="card shadow-sm mb-3">
        <div class="card-body">
          <div class="fw-semibold">Thống kê nhanh</div>
          <hr class="my-2">
          <div class="row g-2">
            <div class="col-6 col-md-3">
              <div class="border rounded p-2 h-100">
                <div class="text-muted small">Listings</div>
                <div class="fw-semibold"><%= @listing_count %></div>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="border rounded p-2 h-100">
                <div class="text-muted small">Orders</div>
                <div class="fw-semibold"><%= @order_count %></div>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="border rounded p-2 h-100">
                <div class="text-muted small">Bids</div>
                <div class="fw-semibold"><%= @bid_count %></div>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="border rounded p-2 h-100">
                <div class="text-muted small">Watchlist</div>
                <div class="fw-semibold"><%= @watchlist_count %></div>
              </div>
            </div>
            <div class="col-6">
              <div class="border rounded p-2 h-100">
                <div class="text-muted small">Tổng coin cộng</div>
                <div class="fw-semibold text-success">+<%= number_with_delimiter(@coins_in_total) %></div>
              </div>
            </div>
            <div class="col-6">
              <div class="border rounded p-2 h-100">
                <div class="text-muted small">Tổng coin trừ</div>
                <div class="fw-semibold text-danger">-<%= number_with_delimiter(@coins_out_total) %></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm mb-3">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div class="fw-semibold">Sản phẩm gần đây</div>
            <div class="text-muted small"><%= @recent_listings.size %></div>
          </div>
          <hr class="my-2">
          <ul class="list-unstyled mb-0">
            <% @recent_listings.each do |l| %>
              <li class="py-2 border-bottom">
                <%= link_to l.title, admin_listing_path(l), class: "text-decoration-none fw-semibold" %>
                <div class="text-muted small">#<%= l.id %> • <%= l.created_at.strftime("%d/%m %H:%M") %></div>
              </li>
            <% end %>
            <% if @recent_listings.blank? %>
              <li class="text-muted">Chưa có listing.</li>
            <% end %>
          </ul>
        </div>
      </div>

      <div class="card shadow-sm mb-3">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div class="fw-semibold">Lịch sử coin gần đây</div>
            <div class="text-muted small"><%= @recent_coin_transactions.size %></div>
          </div>
          <hr class="my-2">
          <ul class="list-unstyled mb-0">
            <% @recent_coin_transactions.each do |tx| %>
              <li class="py-2 border-bottom">
                <div class="d-flex justify-content-between align-items-start gap-2">
                  <div>
                    <div class="fw-semibold"><%= tx.transaction_type.humanize %></div>
                    <div class="text-muted small"><%= tx.description.presence || "(không có mô tả)" %></div>
                    <div class="text-muted small"><%= tx.created_at.strftime("%d/%m %H:%M") %></div>
                  </div>
                  <div class="text-end">
                    <div class="fw-semibold <%= tx.amount >= 0 ? 'text-success' : 'text-danger' %>">
                      <%= tx.amount >= 0 ? '+' : '' %><%= tx.amount %>
                    </div>
                    <div class="text-muted small">Số dư: <%= tx.balance_after %></div>
                  </div>
                </div>
              </li>
            <% end %>
            <% if @recent_coin_transactions.blank? %>
              <li class="text-muted">Chưa có giao dịch coin.</li>
            <% end %>
          </ul>
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div class="fw-semibold">Đơn hàng gần đây (người mua)</div>
            <div class="text-muted small"><%= @recent_orders.size %></div>
          </div>
          <hr class="my-2">
          <ul class="list-unstyled mb-0">
            <% @recent_orders.each do |o| %>
              <li class="py-2 border-bottom">
                <%= link_to "Đơn hàng ##{o.id}", admin_order_path(o), class: "text-decoration-none fw-semibold" %>
                <span class="text-muted small">• <%= o.kind %> • <%= o.status %> • <%= o.price %></span>
              </li>
            <% end %>
            <% if @recent_orders.blank? %>
              <li class="text-muted">Chưa có order.</li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
