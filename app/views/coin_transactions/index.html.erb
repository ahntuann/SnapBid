<div class="container" style="padding-top:92px;padding-bottom:56px;max-width:800px;">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 fw-bold mb-0">Lịch sử giao dịch Coin</h1>
    <div>
      <%= link_to "<i class='bi bi-arrow-left'></i> Quay lại ví".html_safe, wallet_path, class: "btn btn-outline-secondary btn-sm" %>
    </div>
  </div>

  <div class="card border-0 shadow-sm" style="border-radius:16px;">
    <div class="card-body p-4">
      <div class="mb-4 p-3 bg-light rounded-3 d-flex justify-content-between align-items-center">
        <div>
          <div class="text-muted small">Số dư hiện tại</div>
          <div class="fs-4 fw-bold text-primary"><%= number_with_delimiter(current_user.coin_balance) %> <span class="fs-6 fw-normal">Coin</span></div>
        </div>
        <%= link_to "Nạp thêm", wallet_path, class: "btn btn-primary btn-sm" %>
      </div>

      <% if @transactions.empty? %>
        <div class="text-center py-5">
          <i class="bi bi-clock-history fs-1 text-muted mb-3 d-block"></i>
          <p class="text-muted mb-0">Chưa có giao dịch nào.</p>
        </div>
      <% else %>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Thời gian</th>
                <th>Phân loại</th>
                <th>Sự thay đổi</th>
                <th>Số dư</th>
                <th>Mô tả</th>
              </tr>
            </thead>
            <tbody>
              <% @transactions.each do |tx| %>
                <tr>
                  <td class="text-muted small"><%= tx.created_at.strftime("%d/%m/%Y %H:%M") %></td>
                  <td>
                    <% case tx.transaction_type %>
                    <% when "deposit" %>
                      <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2 py-1">Nạp tiền</span>
                    <% when "withdrawal" %>
                      <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-2 py-1">Rút tiền</span>
                    <% when "bid_fee" %>
                      <span class="badge bg-warning bg-opacity-10 text-dark rounded-pill px-2 py-1">Phí đặt giá</span>
                    <% when "refund" %>
                      <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-2 py-1">Hoàn tiền</span>
                    <% when "payment" %>
                      <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-2 py-1">Thanh toán</span>
                    <% else %>
                      <span class="badge bg-light text-dark rounded-pill px-2 py-1"><%= tx.transaction_type %></span>
                    <% end %>
                  </td>
                  <td class="fw-bold <%= tx.amount > 0 ? "text-success" : "text-danger" %>">
                    <%= tx.amount > 0 ? "+" : "" %><%= number_with_delimiter(tx.amount) %>
                  </td>
                  <td class="fw-semibold text-primary"><%= number_with_delimiter(tx.balance_after) %></td>
                  <td class="small text-muted"><%= tx.description %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        
        <div class="mt-4 d-flex justify-content-center">
          <%= paginate @transactions, theme: 'bootstrap-5' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
