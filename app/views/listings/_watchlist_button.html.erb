<% if user_signed_in? && listing.user_id != current_user.id %>
  <% watchlist = current_user.watchlists.find_by(listing: listing) %>
  <% if watchlist %>
    <%= button_to listing_watchlist_path(listing),
          method: :delete,
          class: "btn btn-danger btn-sm rounded-pill",
          style: "font-size:13px;",
          data: { turbo_stream: true } do %>
      <i class="bi bi-heart-fill me-1"></i>Đã theo dõi
    <% end %>
  <% else %>
    <%= button_to listing_watchlist_path(listing),
          method: :post,
          class: "btn btn-outline-secondary btn-sm rounded-pill",
          style: "font-size:13px;",
          data: { turbo_stream: true } do %>
      <i class="bi bi-heart me-1"></i>Theo dõi
    <% end %>
  <% end %>
<% end %>
