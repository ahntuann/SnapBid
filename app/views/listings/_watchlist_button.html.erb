<% if user_signed_in? && listing.user_id != current_user.id %>
  <div id="watchlist_button_<%= listing.id %>">
    <% watchlist = current_user.watchlists.find_by(listing: listing) %>
    <% if watchlist %>
      <%= button_to listing_watchlist_path(listing), 
            method: :delete, 
            class: "btn btn-outline-danger w-100 mt-2 d-flex align-items-center justify-content-center",
            data: { turbo_stream: true } do %>
        <i class="bi bi-heart-fill me-2"></i> Đã theo dõi
      <% end %>
    <% else %>
      <%= button_to listing_watchlist_path(listing), 
            method: :post, 
            class: "btn btn-outline-primary w-100 mt-2 d-flex align-items-center justify-content-center",
            data: { turbo_stream: true } do %>
        <i class="bi bi-heart me-2"></i> Theo dõi sản phẩm
      <% end %>
    <% end %>
  </div>
<% end %>
