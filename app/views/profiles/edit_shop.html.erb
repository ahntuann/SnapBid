<div class="container" style="max-width: 900px;">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h1 class="h4 mb-1">Chỉnh sửa gian hàng</h1>
      <div class="text-muted">Cập nhật thông tin công khai hiển thị trên trang người bán</div>
    </div>
    <div class="d-flex gap-2">
      <%= link_to "Trang của tôi", seller_path(current_user), class: "btn btn-outline-warning btn-sm" %>
      <%= link_to "Quay lại", profile_path, class: "btn btn-outline-secondary btn-sm" %>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <%= form_with model: current_user,
            url: update_shop_profile_path,
            method: :patch,
            local: true do |f| %>

        <div class="mb-3">
          <%= f.label :shop_name, "Tên gian hàng", class: "form-label" %>
          <%= f.text_field :shop_name,
                class: "form-control",
                placeholder: "VD: SnapShop Premium" %>
          <div class="form-text">Tên này sẽ hiển thị nổi bật trên trang công khai của bạn.</div>
        </div>

        <div class="mb-3">
          <%= f.label :location, "Khu vực", class: "form-label" %>
          <%= f.text_field :location,
                class: "form-control",
                placeholder: "VD: Hà Nội" %>
        </div>

        <div class="mb-4">
          <%= f.label :bio, "Giới thiệu gian hàng", class: "form-label" %>
          <%= f.text_area :bio,
                class: "form-control",
                rows: 5,
                placeholder: "Giới thiệu ngắn gọn về gian hàng, sản phẩm, cam kết, chính sách hỗ trợ..." %>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <%= f.submit "Lưu thông tin gian hàng", class: "btn btn-warning" %>
          <%= link_to "Sửa tài khoản", edit_profile_path, class: "btn btn-outline-secondary" %>
          <%= link_to "Huỷ", seller_path(current_user), class: "btn btn-outline-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>