<%# sellers/show.html.erb — Trang hồ sơ người bán công khai %>

<div class="pt-4 pb-5">

  <%# ── Hero card ── %>
  <div class="card border-0 shadow-sm mb-4" style="border-radius:20px; overflow:hidden;">
    <!-- Cover gradient -->
    <div style="height:140px; background:linear-gradient(135deg,#c88a1c 0%,#7a4e00 100%); position:relative;">
      <% if @seller.location.present? %>
        <span class="position-absolute bottom-0 end-0 mb-3 me-4 text-white opacity-75 small">
          <i class="bi bi-geo-alt-fill me-1"></i><%= @seller.location %>
        </span>
      <% end %>
    </div>

    <div class="card-body px-4 pb-4" style="margin-top:-52px;">
      <div class="d-flex align-items-end gap-3 mb-3 flex-wrap">
        <!-- Avatar -->
        <div class="flex-shrink-0">
          <% if @seller.avatar.attached? %>
            <%= image_tag url_for(@seller.avatar), class: "rounded-circle border border-3 border-white shadow",
                  style: "width:96px;height:96px;object-fit:cover;" %>
          <% else %>
            <div class="rounded-circle border border-3 border-white shadow d-flex align-items-center justify-content-center"
                 style="width:96px;height:96px;background:#f3f4f6;">
              <i class="bi bi-person-fill text-muted" style="font-size:2.8rem;"></i>
            </div>
          <% end %>
        </div>

        <!-- Name + badges -->
        <div class="flex-grow-1 pb-1">
          <% if @seller.shop_name.present? %>
            <div class="fw-bold text-warning" style="font-size:13px; letter-spacing:.5px; text-transform:uppercase;">
              <i class="bi bi-shop me-1"></i><%= @seller.shop_name %>
            </div>
          <% end %>
          <div class="d-flex align-items-center gap-2 flex-wrap mt-1">
            <h1 class="h4 fw-bold mb-0"><%= @seller.display_name %></h1>
            <span class="badge text-bg-warning rounded-pill px-3">
              <i class="bi bi-shop me-1"></i>Người bán
            </span>
            <% if @seller.email_verified? %>
              <span class="badge text-bg-success rounded-pill px-3">
                <i class="bi bi-patch-check-fill me-1"></i>Đã xác minh
              </span>
            <% end %>
            <% if @sold_count >= 10 %>
              <span class="badge rounded-pill px-3" style="background:#fff3cd; color:#856404;">
                <i class="bi bi-award-fill me-1"></i>Người bán uy tín
              </span>
            <% end %>
          </div>
          <div class="d-flex flex-wrap gap-3 text-muted small mt-2">
            <span><i class="bi bi-calendar3 me-1"></i>Tham gia từ <%= @seller.created_at.strftime("%m/%Y") %></span>
            <% if @seller.location.present? %>
              <span><i class="bi bi-geo-alt me-1"></i><%= @seller.location %></span>
            <% end %>
          </div>
        </div>

        <!-- Actions -->
        <div class="d-flex flex-column gap-2 align-items-end pb-1">
          <% if user_signed_in? && current_user == @seller %>
            <%= link_to edit_shop_profile_path, class: "btn btn-outline-warning btn-sm rounded-pill" do %>
              <i class="bi bi-pencil me-1"></i>Sửa gian hàng
            <% end %>
          <% elsif user_signed_in? %>
            <button class="btn btn-outline-secondary btn-sm rounded-pill"
                    onclick="navigator.clipboard.writeText(window.location.href).then(() => { this.innerHTML='<i class=\'bi bi-check2 me-1\'></i>Đã sao chép'; setTimeout(() => this.innerHTML='<i class=\'bi bi-share me-1\'></i>Chia sẻ', 2000); })">
              <i class="bi bi-share me-1"></i>Chia sẻ
            </button>
          <% end %>
        </div>
      </div>

      <%# ── Bio ── %>
      <% if @seller.bio.present? %>
        <div class="rounded-3 px-3 py-2 mb-3" style="background:#fdf8f0; border-left:3px solid #c88a1c;">
          <p class="mb-0 text-secondary" style="font-size:14px; line-height:1.6;"><%= @seller.bio %></p>
        </div>
      <% end %>

      <%# ── Stats bar ── %>
      <div class="row g-2 mt-1">
        <div class="col-4">
          <%= link_to seller_path(@seller, tab: "all"), class: "text-decoration-none d-block" do %>
            <div class="text-center rounded-3 py-3 px-1 border <%= @listing_tab == "all" ? "border-primary shadow-sm" : "border-transparent" %>" style="background:#f8f9fa; transition:.2s ease;">
              <div class="fw-bold fs-4 text-primary"><%= @total_listings %></div>
              <div class="text-muted" style="font-size:12px;">Sản phẩm đăng</div>
            </div>
          <% end %>
        </div>
        <div class="col-4">
          <%= link_to seller_path(@seller, tab: "sold"), class: "text-decoration-none d-block" do %>
            <div class="text-center rounded-3 py-3 px-1 border <%= @listing_tab == "sold" ? "border-success shadow-sm" : "border-transparent" %>" style="background:#f0fdf4; transition:.2s ease;">
              <div class="fw-bold fs-4 text-success"><%= @sold_count %></div>
              <div class="text-muted" style="font-size:12px;">Đã bán</div>
            </div>
          <% end %>
        </div>
        <div class="col-4">
          <%= link_to seller_path(@seller, tab: "active"), class: "text-decoration-none d-block" do %>
            <div class="text-center rounded-3 py-3 px-1 border <%= @listing_tab == "active" ? "border-info shadow-sm" : "border-transparent" %>" style="background:#eff6ff; transition:.2s ease;">
              <div class="fw-bold fs-4 text-info"><%= @active_count %></div>
              <div class="text-muted" style="font-size:12px;">Đang đấu giá</div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── Listings grid ── %>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <div>
      <div class="fw-bold" style="font-size:1.1rem;">
        <%= case @listing_tab
            when "all" then "Tất cả sản phẩm đã đăng"
            when "sold" then "Sản phẩm đã bán"
            else "Sản phẩm đang đấu giá"
            end %>
      </div>
      <div class="text-muted small">
        <%= case @listing_tab
            when "all" then "Các sản phẩm công khai của #{(@seller.shop_name.presence || @seller.display_name)}"
            when "sold" then "Các sản phẩm đã giao dịch thành công của #{(@seller.shop_name.presence || @seller.display_name)}"
            else "Các sản phẩm đang bán bởi #{(@seller.shop_name.presence || @seller.display_name)}"
            end %>
      </div>
    </div>
  </div>

  <% if @listings.empty? %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-box-seam fs-1 d-block mb-3 opacity-50"></i>
      <p class="mb-0">
        <%= case @listing_tab
            when "all" then "Người bán này chưa có sản phẩm công khai nào."
            when "sold" then "Người bán này chưa có sản phẩm nào đã bán."
            else "Người bán này chưa có sản phẩm nào đang đấu giá."
            end %>
      </p>
    </div>
  <% else %>
    <div class="row g-3">
      <% @listings.each do |listing| %>
        <%= render "listings/grid_card", listing: listing %>
      <% end %>
    </div>

    <% if @listings.total_pages > 1 %>
      <div class="mt-4 d-flex justify-content-center">
        <%= paginate @listings, params: { tab: @listing_tab } %>
      </div>
    <% end %>
  <% end %>

</div>
