<div id="flash-toast" class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999"
     data-controller="flash-toast">
  <% if notice.present? %>
    <div class="toast align-items-center sb-toast sb-toast--success border-0" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="d-flex">
        <div class="toast-body">
          <i class="bi bi-check-circle-fill"></i>
          <div><%= notice %></div>
        </div>
        <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
      </div>
    </div>
  <% end %>
  <% if alert.present? %>
    <div class="toast align-items-center sb-toast sb-toast--error border-0" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="d-flex">
        <div class="toast-body">
          <i class="bi bi-exclamation-circle-fill"></i>
          <div><%= alert %></div>
        </div>
        <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
      </div>
    </div>
  <% end %>
</div>
