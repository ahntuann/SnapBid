<%# filepath: app/views/wallet/show.html.erb %>
<div class="container" style="padding-top:92px;padding-bottom:56px;max-width:760px;">
  <h1 class="h3 fw-bold mb-1">Ví SnapBid Coin</h1>
  <p class="text-muted mb-4">Nạp tiền để có coin thanh toán đơn hàng</p>

  <%# ── Coin Balance Card ─────────────────────────────────────────────── %>
  <div class="card border-0 shadow-sm mb-4" style="border-radius:16px;background:linear-gradient(135deg,#6366f1,#8b5cf6);">
    <div class="card-body p-4 text-white">
      <div class="small opacity-75 mb-1">Số dư hiện tại</div>
      <div class="d-flex align-items-center gap-3">
        <div style="font-size:2.5rem;font-weight:700;line-height:1;">
          <%= number_with_delimiter(@coin_balance) %>
        </div>
        <div>
          <div class="fw-semibold" style="font-size:1.1rem;">SnapBid Coin</div>
          <div class="opacity-75 small">≈ <%= number_to_currency(@coin_balance * @exchange_rate, unit: "₫", precision: 0, delimiter: ".") %></div>
        </div>
      </div>
    </div>
  </div>

  <%# ── Deposit QR Section ────────────────────────────────────────────── %>
  <div class="card border-0 shadow-sm mb-4" style="border-radius:16px;">
    <div class="card-body p-4">
      <div class="fw-semibold fs-5 mb-1">Nạp SnapBid Coin</div>
      <div class="text-muted small mb-4">
        Quét mã QR bên dưới để chuyển khoản. Hệ thống tự động cộng coin sau khi nhận tiền.
        <br>
        Tỷ lệ quy đổi:
        <span class="fw-semibold text-dark">1.000 ₫ = 1 Coin</span>
      </div>

      <div class="row g-4 align-items-start">
        <div class="col-auto">
          <div class="bg-white rounded border p-2" style="display:inline-block;">
            <%= image_tag sepay_qr_image_url(des: @deposit_ref),
                class: "d-block",
                style: "width:200px;height:200px;",
                alt: "QR nạp SnapBid Coin",
                loading: "lazy" %>
          </div>
        </div>

        <div class="col">
          <div class="mb-3">
            <div class="text-muted small mb-1">Nội dung chuyển khoản <span class="text-danger">(bắt buộc)</span></div>
            <div class="d-flex align-items-center gap-2">
              <code class="badge text-bg-dark fs-6 user-select-all px-3 py-2" id="deposit-ref-badge">
                <%= @deposit_ref %>
              </code>
              <button type="button"
                      class="btn btn-outline-secondary btn-sm"
                      onclick="navigator.clipboard.writeText('<%= @deposit_ref %>').then(()=>{ this.innerHTML='<i class=\'bi bi-check\'></i> Đã copy'; setTimeout(()=>this.innerHTML='<i class=\'bi bi-clipboard\'></i> Copy',2000) })"
                      title="Sao chép">
                <i class="bi bi-clipboard"></i> Copy
              </button>
            </div>
          </div>

          <div class="alert alert-info py-2 px-3 small mb-0">
            <i class="bi bi-info-circle me-1"></i>
            <strong>Quan trọng:</strong> Nhập đúng nội dung
            <strong><%= @deposit_ref %></strong> khi chuyển khoản để hệ thống tự động nhận diện và cộng coin vào tài khoản của bạn.
          </div>

          <div class="mt-3 text-muted small">
            <div class="mb-1"><i class="bi bi-lightning-charge text-warning me-1"></i>Coin được cộng tự động trong vài giây sau giao dịch.</div>
            <div><i class="bi bi-shield-check text-success me-1"></i>Mọi giao dịch được ghi nhận và bảo vệ.</div>
          </div>
        </div>
      </div>

      <%# Bảng quy đổi nhanh %>
      <hr class="my-4">
      <div class="fw-semibold small mb-2">Bảng quy đổi tham khảo</div>
      <div class="table-responsive">
        <table class="table table-sm table-bordered text-center mb-0" style="max-width:360px;">
          <thead class="table-light">
            <tr>
              <th>Số tiền nạp</th>
              <th>SnapBid Coin nhận</th>
            </tr>
          </thead>
          <tbody>
            <% [[10_000,10],[50_000,50],[100_000,100],[500_000,500],[1_000_000,1000]].each do |vnd, coin| %>
              <tr>
                <td><%= number_to_currency(vnd, unit: "₫", precision: 0, delimiter: ".") %></td>
                <td class="fw-semibold text-primary"><%= number_with_delimiter(coin) %> coin</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%# ── Deposit History ────────────────────────────────────────────────── %>
  <div class="card border-0 shadow-sm" style="border-radius:16px;">
    <div class="card-body p-4">
      <div class="fw-semibold fs-5 mb-3">Lịch sử nạp coin</div>

      <% if @recent_deposits.empty? %>
        <div class="text-muted text-center py-3 small">
          <i class="bi bi-inbox fs-3 d-block mb-2"></i>
          Chưa có giao dịch nạp nào.
        </div>
      <% else %>
        <div class="table-responsive">
          <table class="table table-sm mb-0">
            <thead class="table-light">
              <tr>
                <th>Thời gian</th>
                <th class="text-end">Số tiền nạp</th>
                <th class="text-end">Coin nhận</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_deposits.each do |dep| %>
                <tr>
                  <td class="text-muted small">
                    <%= dep.credited_at ? l(dep.credited_at, format: :short) : "-" %>
                  </td>
                  <td class="text-end">
                    <%= number_to_currency(dep.amount_vnd, unit: "₫", precision: 0, delimiter: ".") %>
                  </td>
                  <td class="text-end fw-semibold text-primary">
                    +<%= number_with_delimiter(dep.coins_credited) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </div>
</div>
