<%= turbo_stream.replace "watchlist_button_#{@listing.id}" do %>
  <%= render "listings/watchlist_button", listing: @listing %>
<% end %>

<%= turbo_stream.append "flash-toast" do %>
  <div class="toast align-items-center sb-toast sb-toast--success border-0" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="d-flex">
      <div class="toast-body">
        <i class="bi bi-check-circle-fill"></i>
        <div>Đã thêm vào danh sách theo dõi.</div>
      </div>
      <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
  </div>
<% end %>
