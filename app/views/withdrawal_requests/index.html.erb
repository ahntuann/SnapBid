<div class="container" style="padding-top:92px;padding-bottom:56px;max-width:760px;">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 fw-bold mb-0">Lịch sử rút tiền</h1>
    <div>
      <%= link_to "Quay lại ví", wallet_path, class: "btn btn-outline-secondary btn-sm" %>
      <%= link_to "Tạo yêu cầu mới", new_withdrawal_request_path, class: "btn btn-primary btn-sm ms-2" %>
    </div>
  </div>

  <div class="card border-0 shadow-sm" style="border-radius:16px;">
    <div class="card-body p-4">
      <% if @withdrawal_requests.empty? %>
        <div class="text-muted text-center py-5">
          <i class="bi bi-inbox fs-1 d-block mb-3 text-secondary"></i>
          <p class="mb-0">Bạn chưa có yêu cầu rút tiền nào.</p>
        </div>
      <% else %>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Mã yêu cầu</th>
                <th>Thời gian</th>
                <th>Số lượng coin</th>
                <th>Tài khoản nhận</th>
                <th>Trạng thái</th>
              </tr>
            </thead>
            <tbody>
              <% @withdrawal_requests.each do |req| %>
                <tr>
                  <td><span class="text-muted small">#<%= req.id %></span></td>
                  <td><%= l(req.created_at, format: :short) %></td>
                  <td class="fw-semibold text-danger">-<%= number_with_delimiter(req.amount) %></td>
                  <td>
                    <div class="small">
                      <div class="fw-medium"><%= req.bank_name %></div>
                      <div class="text-muted"><%= req.account_number %> - <%= req.account_name %></div>
                    </div>
                  </td>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <% case req.status %>
                      <% when "pending" %>
                        <span class="badge bg-warning text-dark px-2 py-1 rounded-pill">Đang chờ</span>
                      <% when "completed" %>
                        <span class="badge bg-success px-2 py-1 rounded-pill">Thành công</span>
                        <% if req.transfer_image.attached? %>
                          <%= link_to url_for(req.transfer_image), target: "_blank", class: "btn btn-sm btn-outline-info rounded-pill py-0 px-2", title: "Xem ảnh chuyển khoản" do %>
                            <i class="bi bi-image"></i>
                          <% end %>
                        <% end %>
                      <% when "rejected" %>
                        <span class="badge bg-danger px-2 py-1 rounded-pill">Từ chối</span>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </div>
</div>
